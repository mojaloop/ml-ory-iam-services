{
  "name": "@mojaloop/ml-iam-services",
  "version": "0.1.1",
  "description": "Mojaloop Ory IAM Services - Keto batch auth proxy and Kratos role webhook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mojaloop/ml-iam-services.git"
  },
  "keywords": [
    "mojaloop",
    "ory",
    "keto",
    "kratos",
    "iam",
    "authorization"
  ],
  "author": "Mojaloop Foundation",
  "contributors": [
    "Yevhen Kyriukha <kirgene@gmail.com>"
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/mojaloop/ml-iam-services/issues"
  },
  "homepage": "https://github.com/mojaloop/ml-iam-services#readme",
  "main": "dist/cli.js",
  "bin": {
    "ory-services": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "prepare": "husky || true",
    "prepublishOnly": "npm run build",
    "lint": "eslint src test",
    "lint:fix": "npm run lint -- --fix",
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/cli.js",
    "start:dev": "ts-node src/cli.ts",
    "test": "npm run test:unit",
    "test:unit": "jest --testMatch='**/unit/**/*.test.ts'",
    "test:xunit": "JEST_JUNIT_OUTPUT_DIR=./test/reports/ JEST_JUNIT_OUTPUT_NAME=xunit.xml npm run test:unit -- --reporters=jest-junit",
    "test:coverage": "npm run test:unit -- --coverage --coverageThreshold='{}'",
    "test:coverage-check": "npm run test:unit -- --coverage",
    "test:integration": "./test/scripts/test-integration.sh",
    "test:functional": "echo 'No functional tests yet'",
    "audit:check": "npx audit-ci --config ./audit-ci.jsonc",
    "dep:check": "npx --no-install ncu -e 2",
    "dep:update": "npx --no-install ncu -u",
    "release": "npx commit-and-tag-version --no-verify --releaseCommitMessageFormat 'ci(release): {{currentTag}} [skip ci]'",
    "snapshot": "npx commit-and-tag-version --no-verify --skip.changelog --prerelease snapshot --releaseCommitMessageFormat 'ci(snapshot): {{currentTag}}'"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.59.0",
    "audit-ci": "^7.1.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "commit-and-tag-version": "^12.7.1",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "supertest": "^7.2.2",
    "@types/supertest": "^7.2.0"
  },
  "lint-staged": {
    "./src/*.ts": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  }
}
